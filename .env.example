# ─── Quality Spa Care Chatbot — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to Git — it's already in .gitignore.

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Your Anthropic API key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ── Twilio ─────────────────────────────────────────────────────────────────────
# Find these at https://console.twilio.com → Account Info panel
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio phone number you purchased (include country code, e.g. +18015550100)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Your personal cell phone — where lead notifications will be sent
OWNER_PHONE_NUMBER=+1XXXXXXXXXX

# ── Server ─────────────────────────────────────────────────────────────────────
# The origin allowed to call this API (your Squarespace site URL)
ALLOWED_ORIGIN=https://www.qualityspacare.com

# Port to run the server on (Render/Vercel set this automatically)
PORT=3000
